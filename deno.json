{
  "tasks": {
    "backend": "uv run --project backend uvicorn queryview.main:app --reload --port 8000",
    "frontend": "npm --prefix frontend run dev",
    "dev": "deno run -A npm:concurrently@9 -n backend,frontend -c blue,magenta \"deno task backend\" \"deno task frontend\"",
    "build": "npm --prefix frontend run build",
    "start": "SERVE_STATIC=1 uv run --project backend queryview-backend",
    "preview": "deno task build && deno task start",
    "test:e2e": "deno test -A e2e/"
  },
  "imports": {
    "@astral/astral": "jsr:@astral/astral@^0.5.4",
    "@std/assert": "jsr:@std/assert@^1.0.0"
  },
  "fmt": {
    "exclude": ["**/node_modules", "**/dist"]
  }
}
