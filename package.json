{
  "name": "queryview",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "backend": "uv run --project backend uvicorn queryview.main:app --reload --port 8000",
    "frontend": "npm --prefix frontend run dev",
    "dev": "concurrently -n backend,frontend -c blue,magenta \"npm run backend\" \"npm run frontend\"",
    "build": "npm --prefix frontend run build",
    "start": "SERVE_STATIC=1 uv run --project backend queryview-backend",
    "preview": "npm run build && npm run start",
    "test:e2e": "playwright test"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "concurrently": "^9.2.1"
  }
}
